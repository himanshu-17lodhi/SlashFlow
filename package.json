{
  "name": "slashflow",
  "version": "0.1.0",
  "description": "Advanced Notion-style slash commands for Obsidian.",
  "main": "lib/index.js",
  "type": "module",
  "types": "lib/index.d.ts",
  "homepage": "https://github.com/himanshu-17lodhi/SlashFlow",
  "bugs": {
    "url": "https://github.com/himanshu-17lodhi/SlashFlow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/himanshu-17lodhi/SlashFlow.git"
  },
  "author": "Himanshu Lodhi",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "dev": "rollup --config rollup.config.js -w",
    "docs:dev": "vitepress dev docs --port 3000",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "rollup --config rollup.config.js --environment BUILD:production",
    "build:lib": "tsc --project tsconfig.lib.json",
    "release": "shx mkdir -p dist && shx mv main.js dist/ && shx cp src/styles.css dist/ && shx cp manifest.json dist/",
    "clean": "shx rm -rf dist lib coverage",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.ts,.tsx --fix",
    "format": "prettier --write .",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "icons",
    "slashflow",
    "plugin"
  ],
  "lint-staged": {
    "*.{json,js,ts,jsx,tsx,html,css,md}": [
      "npm run lint",
      "npm run format"
    ]
  },
  "devDependencies": {
    "@codemirror/language": "https://github.com/lishid/cm-language",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@twemoji/api": "^17.0.2",
    "@types/node": "^20.17.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mkdirp": "^3.0.1",
    "monkey-around": "^3.0.0",
    "obsidian": "^1.11.4",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "rollup-plugin-copy": "^3.5.0",
    "shx": "^0.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "5",
    "vitepress": "1.6.4",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "fuse.js": "^7.3.0",
    "jszip": "^3.10.1"
  }
}
